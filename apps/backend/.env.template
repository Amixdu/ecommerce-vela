# Copy to .env and fill in your values.
# NEVER commit .env to version control.
#
# Local dev setup:
#   1. Run `npm run db:up` from the monorepo root to start PostgreSQL via Docker Compose.
#   2. The DATABASE_URL below matches the docker-compose.yml defaults — no changes needed.
#   3. Start the backend with `npm run dev:backend`.

# Database — matches docker-compose.yml defaults for local dev
DATABASE_URL=postgres://postgres:password@localhost:5432/ecommerce

# Medusa
JWT_SECRET=your-jwt-secret-min-32-chars
COOKIE_SECRET=your-cookie-secret-min-32-chars

# Clerk (for verifying tokens from web/mobile)
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Redis (optional — used for queue/events)
REDIS_URL=redis://localhost:6379

# Admin
MEDUSA_ADMIN_ONBOARDING_TYPE=default

# Seed — used only by `npm run seed`
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=your-secure-password
