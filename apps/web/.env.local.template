# Copy to .env.local and fill in your values
# NEVER commit .env.local to version control

# Clerk — use testing tokens in CI, never mock auth headers manually
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Stripe — use Stripe Elements; never store or log PANs
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Backend API
NEXT_PUBLIC_BACKEND_URL=http://localhost:9000
BACKEND_URL=http://localhost:9000

# Store default currency (used to pick the correct price from multi-currency products)
NEXT_PUBLIC_STORE_CURRENCY=aud

# Medusa publishable API key — generate in Medusa admin: Settings → API Keys
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_...
